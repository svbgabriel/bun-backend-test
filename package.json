{
  "name": "bun-backend-test",
  "version": "1.0.0",
  "description": "A small project reworked to study bun",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir ./dist",
    "start": "NODE_ENV=production bun dist/index.js",
    "test": "bun test",
    "format": "bunx --bun @biomejs/biome format --write ./src",
    "lint": "bunx --bun @biomejs/biome lint --write ./src",
    "check": "bunx --bun @biomejs/biome check --write ./src"
  },
  "license": "MIT",
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.3.0",
    "elysia": "1.4.28",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@elysiajs/eden": "^1.4.9",
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.10",
    "typescript": "6.0.3"
  }
}
